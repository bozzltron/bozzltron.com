{
  "name": "bozzltron.com",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint \"themes/attila/scripts/**/*.js\" \"themes/attila/Gruntfile.js\" && stylelint \"themes/attila/source/css/overrides.css\"",
    "version": "cd themes/attila && npm install && ./node_modules/.bin/grunt",
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "server": "hexo server --config _config.local.yml",
    "dev": "npm run server"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "strip-ansi": "^6.0.1"
  },
  "dependencies": {
    "hexo": "^8.1.1",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-feed": "^4.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.1",
    "hexo-server": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "stylelint": "^17.9.1",
    "stylelint-config-recommended": "^18.0.0"
  }
}
