
<%
var excerptText = '';
if (post.excerpt) {
 excerptText = strip_html(post.excerpt).trim();
 excerptText = excerptText.replace(/(\u2026|\.{3})\s*$/, '').trim();
}
var authorLabel = typeof config.author === 'object' ? (config.author.nick || config.author.default || '') : (config.author || '');
if (!authorLabel) authorLabel = config.title;
%>
<article class="post">
	<div class="inner">
		<div class="box post-box">
      <h2 class="post-title">
        <a href="<%- url_for(post.path) %>"><%= post.title %></a>
      </h2>
			<span class="post-meta">
				By
				<a href="<%- url_for('/') %>"><%= authorLabel %></a>
        on 
        <%- partial('post/date', {class_name: 'archive-article-date', date_format: 'MMM D, YYYY', show_relative: true}) %>
			</span>
			<% if (excerptText) { %>
			<p class="post-excerpt"><%= excerptText %>…</p>
			<% } %>
		</div>
	</div>
</article>
