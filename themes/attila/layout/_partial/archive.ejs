<header class="blog-header ">
  <div class="inner">
    <div class="box blog-box">
      <h1 class="blog-name"><%= typeof theme.blog_name === 'string' && theme.blog_name.trim() !== '' ? theme.blog_name : config.title %></h1>
      <% var blogTagline = typeof theme.blog_tagline === 'string' && theme.blog_tagline.trim() !== '' ? theme.blog_tagline : (config.description || ''); %>
      <% if (blogTagline) { %>
      <span class="blog-description"><%= blogTagline %></span>
      <% } %>
    </div>
  </div>
</header>

<div id="index" class="container">

  <main id="main-content" class="content" tabindex="-1">

    <% if (typeof page.total === 'number' && page.total > 1) { %>
    <div class="extra-pagination">
      <nav class="pagination" aria-label="Current page">
        <div class="inner">
          <div class="box pagination-box">
            <span class="pagination-info">Page <%= page.current %> of <%= page.total %></span>
          </div>
        </div>
      </nav>
    </div>
    <% } %>
    <% page.posts.each(function(post, i){ %>
    <%- partial('archive-post', {post: post, even: i % 2 == 0}) %>
    <% }) %>
  </main>
</div>


<% if (page.total > 1){ %>
<nav class="pagination" aria-label="Browse pages">
  <div class="inner">
    <div class="box pagination-box">
      <span class="pagination-info">
        <% var prev_text = "&laquo; " + __('prev');var next_text = __('next') + " &raquo;"%>
        <%- paginator({
            prev_text: prev_text,
            next_text: next_text
          }) %>
      </span>
    </div>
  </div>
</nav>
<% } %>
