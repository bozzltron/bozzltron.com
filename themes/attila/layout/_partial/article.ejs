<%
var metaName = author_display_name(config, config.title);
function authorAvatarAlt() {
  return metaName || '';
}
function navExcerpt(p) {
  if (!p || !p.excerpt) return '';
  return strip_html(String(p.excerpt)).trim();
}
var profileImage = typeof theme.avatar === 'string' && theme.avatar.trim() ? theme.avatar : '/images/app_icons/ios/512.png';
var profileSrc = /^https?:\/\//i.test(profileImage) ? profileImage : url_for(profileImage);
var bustRaw = (typeof theme.avatar_cache_bust === 'string' && theme.avatar_cache_bust.trim()) ? theme.avatar_cache_bust.trim() : '';
var profileBust = (!/^https?:\/\//i.test(profileImage) && bustRaw && /^[a-zA-Z0-9._-]+$/.test(bustRaw)) ? ('?' + bustRaw) : '';
%>
<div class="progress-container">
	<span class="progress-bar" style="width: 0%;"></span>
</div>

<header class="post-header<% if (post.hero) { %> has-cover<% } %>">
	<div class="inner">
		<div class="post-info" role="group" aria-labelledby="post-category-label">
			<span class="post-type" id="post-category-label"><%= __('category') %></span>
			<div class="post-count">
				<%- partial('post/category') %>
			</div>
		</div>
    <%- partial('post/title', {class_name: 'article-title'}) %>
		<div class="post-meta">
			<div class="post-meta-avatars">
					<figure class="post-meta-avatar avatar">
						<a href="<%- url_for('/') %>" class="author-avatar">
								<img class="author-profile-image" src="<%= profileSrc %><%= profileBust %>" alt="<%= authorAvatarAlt() %>">
						</a>
					</figure>
			</div>
			<p class="post-meta-author"><%= metaName %></p>
			<%- partial('post/date', {class_name: 'article-date', date_format: null}) %>
		</div>
		<% if (post.hero) { %>
		<div class="post-cover cover" style="transform: translate3d(0px, 0px, 0px);">
				<% var heroAlt = post.hero_alt || post.hero_title || post.title; %>
				<img sizes="100vw" srcset="<%= post.hero %> 320w,
					<%= post.hero %> 640w,
					<%= post.hero %> 960w,
					<%= post.hero %> 1920w" src="<%= post.hero %>" alt="<%= heroAlt %>"<%
					if (post.hero_title_attr) { %> title="<%= post.hero_title_attr %>"<% }
					%> loading="<%= post.hero_loading || 'eager' %>" decoding="<%= post.hero_decoding || 'async' %>" fetchpriority="high"<%
					if (post.hero_width != null && post.hero_height != null) { %> width="<%= post.hero_width %>" height="<%= post.hero_height %>"<% }
					%>>
		</div>
		<% } %>
	</div>
</header>

<main id="main-content" class="content" tabindex="-1">
	<article class="post">
		<div class="inner">

			<section class="post-content">
        <% if (post.excerpt && index){ %>
          <%- post.excerpt %>
          <% if (theme.excerpt_link){ %>
            <p class="article-more-link">
              <a href="<%- url_for(post.path) %>#more"><%= theme.excerpt_link %></a>
            </p>
          <% } %>
        <% } else if (is_post()) {
            var shareUrlPost = typeof post.permalink === 'string' && post.permalink.trim()
              ? post.permalink.trim()
              : full_url_for(post.path);
            var __body = post.content || '';
            var __refAt = __body.indexOf('<h3 id="References"');
            if (__refAt === -1) __refAt = __body.indexOf('<h2 id="References"');
        %>
          <% if (__refAt !== -1) { %>
            <%- __body.substring(0, __refAt) %>
            <div class="post-share-slot post-share-slot--pre-references">
              <%- partial('share-toolbar', {
                share_url: shareUrlPost,
                share_title: post.title,
                share_text: ''
              }) %>
            </div>
            <%- __body.substring(__refAt) %>
          <% } else { %>
            <%- __body %>
            <div class="post-share-slot post-share-slot--after-body">
              <%- partial('share-toolbar', {
                share_url: shareUrlPost,
                share_title: post.title,
                share_text: ''
              }) %>
            </div>
          <% } %>
        <% } else { %>
          <%- post.content %>
        <% } %>
			</section>


			<% if (!index){ %>
				<section class="post-footer">

					<aside class="post-tags">
						<span class="post-info-label">Topic</span>
						<%- partial('post/tag') %>
					</aside>

				</section>

				<% if ( post.comments && config.disqus_shortname){ %>
					<section class="post-comments" style="display: none;">
						<a id="show-disqus" class="post-comments-activate">Show Comments</a>
						<div id="disqus_thread"></div>
					</section>
				<% } %>

				
				<aside class="post-nav">
					<% if ( post.next ){ %>
						<a class="post-nav-next" href="<%- url_for(post.next.path) %>">
							<section class="post-nav-teaser">
								<i class="icon icon-arrow-left"></i>
								<h2 class="post-nav-title"><%= post.next.title %></h2>
								<% var nx = navExcerpt(post.next); %>
								<% if (nx) { %><p class="post-nav-excerpt"><%= nx %></p><% } %>
								<p class="post-nav-meta"><%- partial('post/date', {post: post.next, date_format: 'MMM D, YYYY', show_relative: true}) %></p>
							</section>
						</a>
					<% } %>
					<% if ( post.prev ){ %>
						<a class="post-nav-prev" href="<%- url_for(post.prev.path) %>">
							<section class="post-nav-teaser">
								<i class="icon icon-arrow-right"></i>
								<h2 class="post-nav-title"><%= post.prev.title %></h2>
								<% var px = navExcerpt(post.prev); %>
								<% if (px) { %><p class="post-nav-excerpt"><%= px %></p><% } %>
								<p class="post-nav-meta"><%- partial('post/date', {post: post.prev, date_format: 'MMM D, YYYY', show_relative: true}) %></p>
							</section>
						</a>
					<% } %>
					<div class="clear"></div>
				</aside>
				

			<% } %>

		</div>
	</article>
</main>
