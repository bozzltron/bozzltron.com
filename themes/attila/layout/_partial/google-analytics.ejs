<%# GA4 Measurement ID (themes/attila/_config.yml `google_analytics: G-xxxx`). Loaded via after-footer. %>
<% var __gaId = theme.google_analytics && String(theme.google_analytics).trim(); if (__gaId && __gaId.indexOf('G-') === 0) { %>
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= __gaId %>"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '<%= __gaId %>');
</script>
<% } %>
