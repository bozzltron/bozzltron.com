<!DOCTYPE html>
<%
var __scheme = ((theme.color_scheme || 'system') + '').toLowerCase();
if (__scheme !== 'system' && __scheme !== 'light' && __scheme !== 'dark') {
  __scheme = 'system';
}
%>
<html lang="<%= config.language || 'en' %>" data-server-scheme="<%= __scheme %>">
<head>
  <meta charset="utf-8">
  <%
  var title = page.title;

  if (is_archive()){
    title = __('archive_a');

    if (is_month()){
      title += ': ' + page.year + '/' + page.month;
    } else if (is_year()){
      title += ': ' + page.year;
    }
  } else if (is_category()){
    title = __('category') + ': ' + page.category;
  } else if (is_tag()){
    title = __('tag') + ': ' + page.tag;
  }

  var docTitleFull = title ? title + ' | ' + config.title : config.title;
  var descSrc = page.description || page.excerpt || page.content || config.description;
  var socialDesc = strip_html(descSrc || '').replace(/\s+/g, ' ').trim().substring(0, 200);

  var canonicalHref = '';
  if (typeof page.permalink === 'string' && page.permalink.trim()) {
    canonicalHref = page.permalink.trim();
  } else if (typeof page.path === 'string' && page.path) {
    try {
      canonicalHref = full_url_for(page.path === 'index.html' ? '/' : page.path);
    } catch (eCanon) {
      canonicalHref = '';
    }
  }
  if (!canonicalHref) {
    try { canonicalHref = full_url_for('/'); } catch (eRoot) { canonicalHref = ''; }
  }

  var headAuthorContent = author_display_name(config, '');
  var gaIdTrim = theme.google_analytics ? String(theme.google_analytics).trim() : '';

  /* Open Graph · https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/meta#property_maps */
  var ogOpts = { fb_admins: theme.fb_admins, fb_app_id: theme.fb_app_id };
  if (theme.twitter && String(theme.twitter).trim()) ogOpts.twitter_id = theme.twitter;
  if (theme.google_plus && String(theme.google_plus).trim()) ogOpts.google_plus = theme.google_plus;
  if (theme.twitter_site && String(theme.twitter_site).trim()) ogOpts.twitter_site = String(theme.twitter_site).trim();
  ogOpts.title = docTitleFull;
  if (socialDesc) ogOpts.description = socialDesc;
  if (canonicalHref) ogOpts.url = canonicalHref;
  var heroOgAlt = '';
  if (is_post() && typeof page.hero === 'string' && page.hero.trim()) {
    ogOpts.image = full_url_for(page.hero.trim());
    ogOpts.twitter_card = 'summary_large_image';
    heroOgAlt = strip_html(String(page.hero_alt || page.hero_title || page.title || '')).replace(/\s+/g, ' ').trim();
    if (heroOgAlt) ogOpts.twitter_image_alt = heroOgAlt.substring(0, 420);
  }
  %>
  <%# Theme classes: set in js/theme-scheme.js (loaded early; picker in footer) %>
  <%- js('js/theme-scheme') %>
  <title><%= docTitleFull %></title>

  <%# HTML5 Boilerplate / MDN: viewport + referrer + theme hints %>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <%# https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/meta/name/referrer %>
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <%# https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/meta/name/color-scheme %>
  <meta name="color-scheme" content="light dark">
  <%# Common mobile UX pattern (Boilerplate); avoids unintended telephone links %>
  <meta name="format-detection" content="telephone=no">
  <meta http-equiv="x-ua-compatible" content="ie=edge">

  <% if (gaIdTrim.indexOf('G-') === 0) { %>
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <link rel="dns-prefetch" href="https://www.google-analytics.com">
  <% } %>

  <meta name="application-name" content="<%= config.title %>">
  <%# https://developer.mozilla.org/en-US/docs/Web/Progressive_web_apps/Manifest/Reference/display %>
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="<%= config.title %>">
  <%# https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/meta/name/apple-mobile-web-app-status-bar-style %>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="apple-touch-icon" href="/images/app_icons/ios/180.png">
  <link rel="apple-touch-icon" sizes="120x120" href="/images/app_icons/ios/120.png">
  <link rel="apple-touch-icon" sizes="152x152" href="/images/app_icons/ios/152.png">
  <link rel="apple-touch-icon" sizes="167x167" href="/images/app_icons/ios/167.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/app_icons/ios/180.png">
  <link rel="apple-touch-icon" sizes="192x192" href="/images/app_icons/ios/192.png">
  <%# Larger icon covers iPad / splash-style contexts where launchers fetch a hi-res bitmap %>
  <link rel="apple-touch-icon" sizes="512x512" href="/images/app_icons/ios/512.png">
  <link rel="manifest" href="/manifest.json" crossorigin="anonymous">

  <%# Separate theme_color values for UA chrome (PWAs): https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/meta/name/theme-color %>
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#141518">

  <% if (headAuthorContent) { %>
  <%# https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/meta/name/author %>
  <meta name="author" content="<%= headAuthorContent %>">
  <% } %>
  <% var keywordsMeta = config.keywords; %>
  <% if (keywordsMeta && typeof keywordsMeta === 'string' && keywordsMeta.trim()) { %>
  <meta name="keywords" content="<%= keywordsMeta.trim() %>">
  <% } else if (Array.isArray(keywordsMeta) && keywordsMeta.length) { %>
  <meta name="keywords" content="<%= keywordsMeta.filter(Boolean).join(', ') %>">
  <% } %>

  <%# Robots directives incl. preview caps (supported by Google, documented on MDN) %>
  <%# https://developers.google.com/search/docs/crawling-indexing/robots-meta-tag %>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <%# Progressive Web Apps on Windows pinning (tile matches light avatar background) %>
  <%# https://learn.microsoft.com/en-us/previous-versions/windows/internet-explorer/ie-developer/platform-apis/dn320426(v=vs.85) %>
  <meta name="msapplication-TileColor" content="#ffffff">
  <meta name="msapplication-TileImage" content="<%= full_url_for('/images/app_icons/android/512.png') %>">

  <%- open_graph(ogOpts) %>
  <% if (canonicalHref) { %>
  <link rel="canonical" href="<%= canonicalHref %>">
  <% } %>
  <%# Twitter consumes these explicitly alongside og:* (see Twitter Cards docs linked from MDN OG article) %>
  <meta name="twitter:title" content="<%= docTitleFull %>">
  <% if (socialDesc) { %>
  <meta name="twitter:description" content="<%= socialDesc %>">
  <% } %>
  <% if (is_post() && typeof page.hero === 'string' && page.hero.trim() && page.hero_width != null && page.hero_height != null) {
    var heroAltForMeta = heroOgAlt || strip_html(String(page.title || '')).trim();
    var heroAltEscaped = heroAltForMeta.replace(/"/g, '&quot;').replace(/</g, '');
  %>
  <meta property="og:image:width" content="<%= page.hero_width %>">
  <meta property="og:image:height" content="<%= page.hero_height %>">
  <meta property="og:image:alt" content="<%= heroAltEscaped %>">
  <% } %>
  <%- partial('structured-data-site') %>
  <%- partial('structured-data-post') %>
  <%#
    Syndication discovery: Atom + RSS 2.0 with correct MIME types (WHATWG/HTML + RSS Board practice).
    When both tags exist, hexo-generator-feed skips injecting duplicates (autodiscovery filter).
    See root _config.yml `feed`.
  %>
  <% if (config.feed && config.feed.enable !== false) {
      var syndTypes = config.feed.type;
      var syndPaths = config.feed.path;
      if (typeof syndTypes === 'string') { syndTypes = [syndTypes]; syndPaths = [syndPaths]; }
      var syndMime = { atom: 'application/atom+xml', rss2: 'application/rss+xml' };
      var syndLabel = { atom: 'Atom', rss2: 'RSS 2.0' };
      if (Array.isArray(syndTypes) && Array.isArray(syndPaths)) {
        for (var si = 0; si < syndTypes.length; si++) {
          var st = syndTypes[si];
          var sp = syndPaths[si];
          if (!sp) continue;
  %>
  <link rel="alternate" href="<%= full_url_for(sp) %>" type="<%= syndMime[st] || 'application/xml' %>" title="<%= config.title %> — <%= syndLabel[st] || st %> feed">
  <%    }
      }
  } else if (theme.rss) { %>
  <link rel="alternate" href="<%= full_url_for(theme.rss) %>" type="application/rss+xml" title="<%= config.title %> — feed">
  <% } %>
  <% if (theme.favicon){ %>
    <%# PNG favicon: https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Attributes/rel/icon %>
    <link rel="icon" href="<%- theme.favicon %>" type="image/png">
  <% } %>
  <% if (config.highlight.enable){ %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css?family=Source+Code+Pro" rel="stylesheet" type="text/css">
  <% } %>
  <%
  var accent = theme.accent_color || '#15171A';
  if (!/^#[0-9A-Fa-f]{3,8}$/.test(accent)) accent = '#15171A';
  var accentDark = theme.darkmode_accent_color;
  if (accentDark && !/^#[0-9A-Fa-f]{3,8}$/.test(accentDark)) accentDark = null;
  %>
  <style>:root{
  --ghost-accent-color: <%= accent %>;
  --gh-font-body: Cardo, Georgia, serif;
  --gh-font-heading: 'Fira Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}<%
  if (accentDark) {
%>.theme-dark:root {
  --ghost-accent-color: <%= accentDark %>;
}
@media (prefers-color-scheme: dark) {
  html:not(.theme-light):root {
    --ghost-accent-color: <%= accentDark %>;
  }
}
<% } %></style>
  <link rel="stylesheet" href="/css/fonts-icons.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/overrides.css">
  <style id="fit-vids-style">
.fluid-width-video-wrapper {
	width: 100%;
	position: relative;
	padding: 0;
}
.fluid-width-video-wrapper iframe,
.fluid-width-video-wrapper object,
.fluid-width-video-wrapper embed {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
}
  </style>
  <script>
(function () {
  if (typeof navigator === 'undefined') return;
  if (!('standalone' in navigator) || navigator.standalone) return;
  var s = document.createElement('script');
  s.src = '<%- url_for("/js/pwacompat.min.js") %>';
  s.async = true;
  document.head.appendChild(s);
})();
  </script>
</head>
