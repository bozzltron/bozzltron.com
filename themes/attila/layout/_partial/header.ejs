<% 
function slugLabel(l) {
  return String(l).toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
}
function menuItemActive(href) {
  if (!href || href === '/' || href === '') {
    var p = String(page.path || '').replace(/^\/+/, '').replace(/\/+$/, '');
    if (p === 'index.html' || p === '') return true;
    return /^page\/\d+(\/.*)?$/.test(p);
  }
  var normalized = String(href).replace(/^\/+|\/+$/g, '');
  var arc = String(config.archive_dir || 'archives').replace(/^\/+|\/+$/g, '');
  if (normalized === arc || normalized.indexOf(arc + '/') === 0) {
    return is_archive();
  }
  return is_current(href, false);
}
%>
<div class="nav-header">
  <nav class="nav-wrapper" aria-label="Primary">
    <ul class="site-nav-links">
      <% for (var label in theme.menu) { %>
      <% var href = theme.menu[label]; %>
      <li class="nav-<%- slugLabel(label) %><%= menuItemActive(href) ? ' active' : '' %>">
        <a href="<%- url_for(href) %>"><span><%= label %></span></a>
      </li>
      <% } %>
    </ul>

    <ul class="nav-side">
      <% if (theme.rss){ %>
      <li class="nav-rss">
        <a id="nav-rss-link" class="nav-icon" href="<%- url_for(theme.rss) %>" title="<%= __('rss_feed') %>"
           aria-label="<%= __('rss_feed') %>">
          <i class="icon icon-rss" aria-hidden="true"></i>
        </a>
      </li>
      <% } %>
      <li class="nav-search" style="display: none;"><a title="Search"><i
            class="icon icon-search" aria-hidden="true"></i><span>Search</span></a></li>
    </ul>
  </nav>

  <div class="nav-wrapper-control">
    <div class="inner">
      <a class="nav-menu" href="#" aria-label="Menu"><i class="icon icon-menu" aria-hidden="true"></i>Menu</a>
      <a class="nav-search" style="display: none;" title="Search"><i
          class="icon icon-search" aria-hidden="true"></i><span>Search</span></a>
    </div>
  </div>
</div>
<div class="nav-close"></div>

<section class="page-wrapper">
